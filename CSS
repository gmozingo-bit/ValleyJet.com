/* Global font override */
html,
body,
body * {
    font-family: Helvetica, Arial, sans-serif !important;
}
/* Visually hidden — in DOM for SEO crawlers, invisible to users */
.visually-hidden {
  position: absolute !important;
  width: 1px !important;
  height: 1px !important;
  padding: 0 !important;
  margin: -1px !important;
  overflow: hidden !important;
  clip: rect(0, 0, 0, 0) !important;
  clip-path: inset(50%) !important;
  white-space: nowrap !important;
  border: 0 !important;
  color: transparent !important;
  background: transparent !important;
  pointer-events: none !important;
}
/* --- 1. NEW: DESKTOP VIDEO & POSTER SCALING --- */
@keyframes heroFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

.video-container {
    animation: heroFadeIn 1.5s ease-in-out;
    background-color: #000; 
    overflow: hidden;
    height: calc(100vh - 90px) !important; 
    width: 100vw !important;
    position: relative;
    margin: 0;
    padding: 0;
    left: 50%;
    transform: translateX(-50%);
}

/* This forces the video and poster to be the exact same size */
.video-hero {
    width: 100vw !important;
    height: calc(100vh - 90px) !important; 
    display: block;
    object-fit: cover !important; 
    object-position: center 30%; 
    min-width: 100% !important; 
    min-height: 100% !important;
    transform: scale(1.02); 
}

/* --- 1b. MOBILE VIDEO HERO --- */
.mobile-video-hero {
    display: none; /* Hidden on desktop by default */
}

@media (max-width: 768px) {
    .mobile-video-hero {
        display: block;
        width: 100vw;
        position: relative;
        left: 50%;
        transform: translateX(-50%);
        height: calc(100vh - 90px);
        overflow: hidden;
        background: #000;
        animation: heroFadeIn 1.5s ease-in-out;
    }
    .mobile-video-hero video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .mobile-hero-overlay {
        position: absolute;
        top: 0;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 40px 24px;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        background: linear-gradient(to top, rgba(0,0,0,.75) 0%, rgba(0,0,0,.45) 40%, rgba(0,0,0,.15) 70%, rgba(0,0,0,.05) 100%);
    }
    .mobile-hero-overlay h1 {
        font-size: 2.2rem;
        font-weight: 800;
        color: #fff;
        line-height: 1.1;
        margin: 0 0 8px 0;
        text-transform: uppercase;
        letter-spacing: .02em;
    }
    .mobile-hero-overlay p {
        font-size: .85rem;
        color: rgba(255,255,255,.8);
        margin: 0;
        letter-spacing: .04em;
    }
    .mobile-hero-btn {
        display: inline-block;
        margin-top: 16px;
        padding: 12px 32px;
        background: #FF533D;
        color: #fff;
        font-size: .9rem;
        font-weight: 700;
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: .1em;
        border: none;
        transition: background .3s;
    }
}

