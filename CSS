/* 4. FULL-SCREEN AIRCRAFT SNAP LAYOUT */

/* BREAKOUT: Forces the container to ignore theme boundaries */
.aircraft-showcase {
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    height: 100vh;
    overflow-y: scroll;
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
    background: #000; /* Dark background to prevent white flashes */
}

/* Adjust focal point to show more chairs in Large Cabin */
.aircraft-showcase .aircraft-slide:first-child {
    background-position: center 100% !important;
}

/* Ensure images cover the full screen */
.aircraft-slide {
    width: 100vw;
    height: 100vh;
    background-size: cover;
    background-position: center;
    scroll-snap-align: start;
    display: flex;
    align-items: flex-end;
    padding: 10vh 10vw; /* Responsive padding */
}
/* Info Overlay Box - Updated with Valley Jet Navy */
.info-overlay {
    background: rgba(15, 22, 38, 0.85); /* Valley Jet Navy with transparency */
    backdrop-filter: blur(10px); 
    padding: 40px;
    max-width: 500px;
    color: #fff;
    border-left: 4px solid #FF533D; /* Valley Jet Fast Orange Accent */
    animation: fadeInUp 1s ease-out;
}

.category-label {
    display: block;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 12px;
    margin-bottom: 10px;
    color: #FF533D; /* Fast Orange for small labels */
}

/* Primary Button - Updated with Fast Orange */
.btn-primary {
    display: inline-block;
    background: #FF533D; /* Fast Orange */
    color: #fff;
    padding: 12px 30px;
    text-decoration: none;
    font-weight: bold;
    margin-top: 20px;
    transition: 0.3s;
    border: none;
}

.btn-primary:hover {
    background: #fff;
    color: #0F1626; /* Navy text on white hover */
}

/* Simple Animation */
@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
}

