/* ── PAGE-SPECIFIC VARIABLES ── */
:root {
  --vj-navy:  #0F1626;
  --vj-orange:#FF533D;
  --vj-white: #ffffff;
  --vj-light: #f5f6f8;
  --vj-muted: #6c757d;
}

/* ── HERO BANNER ── */
.lv-hero {
  width: 100vw;
  position: relative;
  left: 50%;
  right: 50%;
  margin-left: -50vw;
  margin-right: -50vw;
  min-height: 88vh;
  background:
    linear-gradient(to right, rgba(15,22,38,.92) 45%, rgba(15,22,38,.45) 100%),
    url('https://valleyjet.com/wp-content/uploads/2020/09/LasVegas_banner.jpg') center 35% / cover no-repeat;
  display: flex;
  align-items: center;
  padding: 10vh 10vw;
  animation: heroFadeIn 1.5s ease-in-out;
}

.lv-hero-inner { max-width: 620px; }

.lv-eyebrow {
  display: block;
  text-transform: uppercase;
  letter-spacing: 3px;
  font-size: 11px;
  color: var(--vj-orange);
  margin-bottom: 16px;
}

.lv-hero h1 {
  font-size: clamp(2.4rem, 5vw, 4.2rem);
  font-weight: 700;
  color: var(--vj-white);
  line-height: 1.1;
  margin-bottom: 20px;
}

.lv-hero h1 span { color: var(--vj-orange); }

.lv-hero p {
  font-size: 1.05rem;
  color: rgba(255,255,255,.75);
  max-width: 480px;
  line-height: 1.7;
  margin-bottom: 32px;
}

.lv-hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; }

.btn-outline-vj {
  display: inline-block;
  background: transparent;
  color: var(--vj-white);
  padding: 12px 28px;
  text-decoration: none;
  font-weight: 600;
  font-size: .85rem;
  letter-spacing: .05em;
  border: 2px solid rgba(255,255,255,.70);
  transition: border-color .25s, color .25s;
}
.btn-outline-vj:hover {
  border-color: var(--vj-orange);
  color: var(--vj-orange);
  text-decoration: none;
}
.btn-primary:focus-visible,
.btn-outline-vj:focus-visible {
  outline: 3px solid var(--vj-orange);
  outline-offset: 3px;
}
.lv-aircraft-card:focus-visible {
  outline: 2px solid var(--vj-orange);
  outline-offset: 2px;
}

/* ── STATS STRIP ── */
.lv-stats {
  width: 100vw;
  position: relative;
  left: 50%;
  right: 50%;
  margin-left: -50vw;
  margin-right: -50vw;
  background: var(--vj-navy);
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border-top: 3px solid var(--vj-orange);
}

.lv-stat {
  padding: 2.2rem 1.5rem;
  text-align: center;
  border-right: 1px solid rgba(255,255,255,.08);
}
.lv-stat:last-child { border-right: none; }

.lv-stat-num {
  display: block;
  font-size: 2.4rem;
  font-weight: 800;
  color: var(--vj-orange);
  line-height: 1;
}
.lv-stat-label {
  display: block;
  font-size: .7rem;
  letter-spacing: .18em;
  text-transform: uppercase;
  color: rgba(255,255,255,.80);
  margin-top: .4rem;
}

/* ── SECTION DEFAULTS ── */
.lv-section {
  padding: 80px 0;
}
.lv-section-dark {
  background: var(--vj-navy);
  color: var(--vj-white);
  width: 100vw;
  position: relative;
  left: 50%;
  right: 50%;
  margin-left: -50vw;
  margin-right: -50vw;
  padding: 80px 10vw;
}
.lv-section-light {
  background: var(--vj-light);
  width: 100vw;
  position: relative;
  left: 50%;
  right: 50%;
  margin-left: -50vw;
  margin-right: -50vw;
  padding: 80px 10vw;
}

.lv-eyebrow-sm {
  display: block;
  text-transform: uppercase;
  letter-spacing: 3px;
  font-size: 11px;
  color: var(--vj-orange);
  margin-bottom: 10px;
}

.lv-section h2 {
  font-size: clamp(1.8rem, 3.5vw, 2.8rem);
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 20px;
  color: inherit;
}
.lv-section-dark h2 { color: var(--vj-white); }
.lv-section-dark p  { color: rgba(255,255,255,.72); }

/* ── TWO-COL INTRO ── */
.lv-two-col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: center;
}

.lv-intro-img {
  position: relative;
}
.lv-intro-img img {
  width: 100%;
  height: 480px;
  object-fit: cover;
  display: block;
}
.lv-intro-badge {
  position: absolute;
  bottom: -20px;
  right: -20px;
  background: var(--vj-orange);
  color: var(--vj-white);
  padding: 22px 28px;
  text-align: center;
  font-weight: 700;
  border: 3px solid var(--vj-white);
  box-shadow: 0 4px 20px rgba(0,0,0,.15);
}
.lv-intro-badge strong {
  display: block;
  font-size: 2rem;
  line-height: 1;
  letter-spacing: .08em;
}
.lv-intro-badge span {
  display: block;
  font-size: .7rem;
  letter-spacing: .2em;
  text-transform: uppercase;
  margin-top: 6px;
  opacity: .9;
}

/* ── AIRCRAFT CARDS ── */
.lv-aircraft-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  margin-top: 40px;
}

.lv-aircraft-card {
  background: rgba(255,255,255,.05);
  border-top: 3px solid transparent;
  padding: 30px 24px;
  transition: border-color .3s, background .3s;
}
.lv-aircraft-card:hover {
  border-color: var(--vj-orange);
  background: rgba(255,83,61,.07);
}

.lv-ac-type {
  display: block;
  font-size: .68rem;
  letter-spacing: .25em;
  text-transform: uppercase;
  color: var(--vj-orange);
  margin-bottom: 6px;
}
.lv-ac-name {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--vj-white);
  margin-bottom: 10px;
}
.lv-aircraft-card p {
  font-size: .88rem;
  color: rgba(255,255,255,.6);
  margin-bottom: 0;
  line-height: 1.5;
}
.lv-ac-specs {
  display: flex;
  justify-content: space-between;
  font-size: .78rem;
  color: rgba(255,255,255,.4);
  border-top: 1px solid rgba(255,255,255,.1);
  padding-top: 12px;
  margin-top: 14px;
}

/* ── SERVICES GRID ── */
.lv-services-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  margin-top: 40px;
}

.lv-service-item {
  display: flex;
  gap: 20px;
  align-items: flex-start;
}

.lv-service-icon {
  flex-shrink: 0;
  width: 46px;
  height: 46px;
  background: var(--vj-orange);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 1.1rem;
}

.lv-service-item h3 {
  font-size: 1rem;
  font-weight: 700;
  color: var(--vj-navy);
  margin-bottom: 6px;
}
.lv-service-item p {
  font-size: .9rem;
  color: var(--vj-muted);
  margin: 0;
}

/* ── AIRPORTS ── */
.lv-airport-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: start;
  margin-top: 30px;
}

.lv-airport-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.lv-airport-list li {
  border-bottom: 1px solid rgba(255,255,255,.08);
}
.lv-airport-list a {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 0;
  color: var(--vj-white);
  text-decoration: none;
  font-size: .9rem;
  transition: color .2s;
}
.lv-airport-list a:hover { color: var(--vj-orange); text-decoration: none; }
.lv-airport-code {
  font-size: 1.4rem;
  font-weight: 800;
  color: var(--vj-orange);
  margin-right: 14px;
  min-width: 52px;
  display: inline-block;
}
.lv-airport-arrow { color: rgba(255,255,255,.3); transition: transform .2s; }
.lv-airport-list a:hover .lv-airport-arrow {
  transform: translateX(4px);
  color: var(--vj-orange);
}

.lv-map-wrap {
  border: 1px solid rgba(255,83,61,.25);
}
.lv-map-wrap iframe {
  width: 100%;
  height: 360px;
  display: block;
  filter: grayscale(70%) contrast(1.1);
}

/* ── CTA BANNER ── */
.lv-cta-banner {
  width: 100vw;
  position: relative;
  left: 50%;
  right: 50%;
  margin-left: -50vw;
  margin-right: -50vw;
  background:
    linear-gradient(rgba(15,22,38,.88), rgba(15,22,38,.88)),
    url('https://images.unsplash.com/photo-1605493624455-a56d6d312b6f?auto=format&fit=crop&w=1400&q=80') center/cover no-repeat;
  padding: 90px 10vw;
  text-align: center;
  color: var(--vj-white);
}
.lv-cta-banner h2 {
  font-size: clamp(1.8rem, 3vw, 2.6rem);
  font-weight: 700;
  max-width: 650px;
  margin: 0 auto 16px;
  color: var(--vj-white);
}
.lv-cta-banner p {
  max-width: 480px;
  margin: 0 auto 32px;
  color: rgba(255,255,255,.7);
}

/* ── RESPONSIVE ── */
@media (max-width: 867px) {
  .lv-hero {
    min-height: auto;
    padding: 100px 6vw 60px;
    background-position: 70% center;
  }
  .lv-stats {
    grid-template-columns: repeat(2, 1fr);
  }
  .lv-stat { border-right: none; border-bottom: 1px solid rgba(255,255,255,.08); }
  .lv-two-col,
  .lv-aircraft-grid,
  .lv-services-grid,
  .lv-airport-grid { grid-template-columns: 1fr; }
  .lv-aircraft-grid { gap: 1px; }
  .lv-intro-badge { right: 0; bottom: 0; }
  .lv-section-dark,
  .lv-section-light { padding: 60px 6vw; }
  .lv-intro-img img { height: 280px !important; object-fit: cover; }
  /* Wing image in brand intro overrides the 280px cap — see mobile split block below */
  .lv-wing-img img { height: auto !important; }
  .lv-intro-img { margin-bottom: 24px; }
}

/* ── NEWSLETTER VIDEO BG: hidden on desktop ── */
.newsletter-video-wrap { display: none; }

