  img[src*="XLS-in-snow-scaled.png"] {
    display: none !important;
    height: 0 !important;
    max-height: 0 !important;
    min-height: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
    overflow: hidden !important;
    visibility: hidden !important;
  }

  /* 2) Aspen card section: text at top over background image */
  .lv-section-light.lv-winter-section {
    position: relative !important;
    background-image: url('https://valleyjet.com/wp-content/uploads/2026/03/16-9SnowXLS-2.png') !important;
    background-repeat: no-repeat !important;
    background-position: top center !important;
    background-size: 100% auto !important;
    background-color: #0F1626 !important;
    min-height: clamp(300px, 56.25vw, 520px) !important;
    padding-top: 2em !important;
    padding-bottom: 2em !important;
    overflow: hidden !important;
  }

  /* 3) Overlay darkens the top so text is readable */
  .lv-section-light.lv-winter-section::before {
    content: '' !important;
    position: absolute !important;
    inset: 0 !important;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.55) 0%,
      rgba(0,0,0,0.45) 25%,
      rgba(0,0,0,0.08) 55%,
      rgba(0,0,0,0.0) 100%
    ) !important;
    pointer-events: none !important;
  }

  /* 4) Hide inner Aspen image inside the card */
  .lv-section-light.lv-winter-section .lv-intro-img,
  .lv-section-light.lv-winter-section .lv-intro-img img {
    display: none !important;
  }

  /* 5) Keep text above overlay */
  .lv-section-light.lv-winter-section .lv-two-col {
    display: block !important;
    position: relative !important;
    z-index: 2 !important;
    max-width: 100% !important;
    margin: 0 auto !important;
  }

  .lv-section-light.lv-winter-section .lv-eyebrow-sm,
  .lv-section-light.lv-winter-section h2,
  .lv-section-light.lv-winter-section p {
    color: #ffffff !important;
  }

  .lv-section-light.lv-winter-section .btn-primary {
    display: block !important;
    width: 100% !important;
    text-align: center !important;
    box-sizing: border-box !important;
  }
}

/* =================================================
   MOBILE FIX — Remove Aspen bottom black bar
   ================================================= */
@media (max-width: 768px) {

  .lv-winter-section {
    background-size: 100% auto !important;
    background-position: top center !important;
    background-repeat: no-repeat !important;

    padding-top: 2em !important;
    padding-bottom: 2em !important;

    min-height: clamp(300px, 56.25vw, 520px) !important;
    height: auto !important;
  }

  /* Remove dark background that shows as black bar */
  .lv-winter-section {
    background-color: transparent !important;
  }

}

