    color: rgba(255, 255, 255, 0.78);
  }
  .newsletter-featured-card p strong {
    color: var(--vj-white);
  }
  .newsletter-featured-card .btn-primary {
    display: block !important;
    width: 100% !important;
    text-align: center !important;
    box-sizing: border-box;
    padding: 16px 30px;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 28px;
    box-shadow: 0 4px 18px rgba(255, 83, 61, 0.40);
  }

  /* ── FAQ collapsible (mobile only) ── */
  .faq-empty-leg {
    margin: 12px 0 4px;
  }
  .faq-empty-leg summary {
    cursor: pointer;
    font-weight: 600;
    color: var(--vj-orange);
    font-size: 0.95rem;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .faq-empty-leg summary::-webkit-details-marker { display: none; }
  .faq-empty-leg summary::after {
    content: '+';
    font-size: 1.2rem;
    line-height: 1;
    transition: content 0.2s;
  }
  .faq-empty-leg[open] summary::after {
    content: '\2212'; /* − */
  }
  .faq-empty-leg > p {
    margin-top: 10px;
    font-size: 0.9rem;
  }
}

/* ── FAQ: desktop — show as plain text, no toggle ── */
@media (min-width: 868px) {
  .faq-empty-leg summary {
    display: none;
  }
  .faq-empty-leg > p {
    display: block !important;
  }
}

/* ══════════════════════════════════════════════════════════
   HOMEPAGE-SPECIFIC COMPONENTS
   ══════════════════════════════════════════════════════════ */

/* ── DESTINATIONS GRID ── */
.hp-destinations-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2px;
  margin-top: 40px;
}

.hp-dest-card {
  background: rgba(255,255,255,.04);
  overflow: hidden;
  transition: background .3s;
}
.hp-dest-card:hover {
  background: rgba(255,83,61,.06);
}

.hp-dest-card img {
  width: 100%;
  height: 260px;
  object-fit: cover;
  display: block;
}

.hp-dest-content {
  padding: 28px 24px;
}

.hp-dest-content h3 {
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--vj-white);
  margin-bottom: 10px;
}

.hp-dest-content p {
  font-size: .88rem;
  color: rgba(255,255,255,.6);
  line-height: 1.6;
  margin-bottom: 0;
}

/* ── CUSTOMER LOGO GRID ── */
.hp-logo-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 40px;
  align-items: center;
  max-width: 1000px;
  margin: 0 auto;
}

.hp-logo-item {
  text-align: center;
}

.hp-logo-item img {
  max-width: 80%;
  height: auto;
  filter: grayscale(100%);
  opacity: .6;
  transition: filter .3s, opacity .3s;
}

.hp-logo-item img:hover {
  filter: grayscale(0%);
  opacity: 1;
}

/* ── FULL-WIDTH IMAGE BREAK ── */
.hp-full-img {
  width: 100vw;
  position: relative;
  left: 50%;
  right: 50%;
  margin-left: -50vw;
  margin-right: -50vw;
  overflow: hidden;
  max-height: 500px;
}

.hp-full-img img {
  width: 100%;
  height: 500px;
  object-fit: cover;
  display: block;
}

.hp-full-img--charter-jet img {
  object-position: center 38%;
}

/* ── CHARTER JET IMAGE: mobile/desktop swap ── */
.hp-charter-mobile-img { display: none; }

@media (max-width: 867px) {
  /* Wrapper: image + badge fill exactly one screen */
  .hp-charter-homebase-wrap {
    display: flex;
    flex-direction: column;
    height: 100vh;
    overflow: hidden;
  }

  /* Direct mobile image child — grows to fill remaining height */
  .hp-charter-homebase-wrap > .hp-charter-mobile-img {
    flex: 1;
    min-height: 0;
    width: 100%;
    object-fit: contain;
    object-position: center center;
  }

  /* Image div grows to fill remaining height after badge */
  .hp-charter-homebase-wrap .hp-full-img {
    flex: 1;
    height: auto;
    max-height: none;
  }

  /* Show full mobile image — no cropping */
  .hp-charter-homebase-wrap .hp-full-img img,
  .hp-charter-homebase-wrap .hp-full-img .hp-charter-mobile-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center center;
  }

  .hp-charter-desktop-img { display: none; }
  .hp-charter-mobile-img  { display: block; }
}

/* ── HOMEPAGE RESPONSIVE ── */
@media (max-width: 867px) {
  .hp-destinations-grid {
    grid-template-columns: 1fr;
  }
  .hp-dest-card img {
    height: 200px;
  }
  .hp-logo-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .hp-full-img,
  .hp-full-img img {
    height: 280px;
  }
  /* Charter section overrides the 280px cap — sized by 100vh wrapper */
  .hp-charter-homebase-wrap .hp-full-img,
  .hp-charter-homebase-wrap .hp-full-img img {
    height: auto;
  }
}

/* ── HOME BASE BADGE ── */
.lv-homebase-badge-section {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60px 6vw;
}
.lv-homebase-badge-section img {
  max-width: 320px;
  width: 100%;
  height: auto;
}

/* ── MOBILE: Winter Getaway full-width background image ── */
@media (max-width: 867px) {
